# =====================================================
# 雕龙绣虎 公众号自动推送配置
# 复制此文件为 .env 并填写真实值
# ⚠️  .env 文件包含敏感凭据，勿提交到 Git
# =====================================================

# 微信公众号（必填）
WX_APPID=your_appid_here
WX_APPSECRET=your_appsecret_here

# DeepSeek AI API（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 公众号名称（可选，默认：雕龙绣虎）
ACCOUNT_NAME=雕龙绣虎

# Pexels API Key（可选，不填则降级 Picsum 兜底封面）
PEXELS_API_KEY=your_pexels_api_key_here

# 状态文件路径（可选，默认 ./state.json）
STATE_FILE=./state.json
